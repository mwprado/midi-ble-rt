[daemon]
# Global ALSA client name used by the daemon.
client_name = midi-ble-rt

[defaults]
# Defaults inherited by entries in devices.d/*.ini unless overridden.
pair = no
trust = yes
reconnect_on_link_loss = yes
enable_tx = yes
profile = standard_ble_midi

[gatt]
# Official BLE-MIDI service and I/O characteristic UUIDs.
service_uuid = 03b80e5a-ede8-4b33-a751-6ce34ec4c700
io_uuid = 7772e5db-3868-4112-a1a9-f2669d106bf3

# Keep generic daemon defaults vendor-neutral.
io_uuid_alias =
require_notify = yes
require_write_without_response = yes

[stats]
enabled = yes
interval_ms = 1000
latency_diagnostics = no

[realtime]
# Optional RtKit scheduling for runtime workers.
# Global safety switch. Keep disabled until after collecting a baseline.
rtkit = no

# Priority is intentionally conservative.
rt_priority = 1

# Directional worker selection used when rtkit = yes.
# RX is the useful DAW input path for BLE-MIDI -> ALSA.
# TX is disabled by default because baseline testing showed worse TX worst-case jitter.
realtime_rx = yes
realtime_tx = no

[debug]
print_ble_packets = no
print_midi_events = no
