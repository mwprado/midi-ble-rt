 }
+
+static void lifecycle_command_free(LifecycleCommand *cmd) {
+    if (!cmd)
+        return;
+    g_free(cmd->reason);
+    g_free(cmd);
+}
+
+static gboolean lifecycle_process_next_cb(gpointer user_data);
+
+static void runtime_lifecycle_schedule(ConfigDirRuntime *rt) {
+    if (!rt || rt->lifecycle_source_id)
+        return;
+
+    rt->lifecycle_source_id = g_idle_add(lifecycle_process_next_cb, rt);
+}
+
+static void runtime_lifecycle_queue_connect(ConfigDeviceRuntime *dev,
+                                            const char *reason) {
+    if (!dev || !dev->owner || !dev->owner->lifecycle_queue)
+        return;
+
+    if (dev->lifecycle_connect_queued || device_session_is(dev, MB_SESSION_STREAMING))
+        return;
+
+    LifecycleCommand *cmd = g_new0(LifecycleCommand, 1);
+    cmd->type = LIFECYCLE_CMD_CONNECT;
+    cmd->dev = dev;
+    cmd->reason = g_strdup(reason);
+
+    dev->lifecycle_connect_queued = true;
+    g_queue_push_tail(dev->owner->lifecycle_queue, cmd);
+
+    g_print("%s lifecycle queued for %s.\n",
+            printable_string(reason, "BlueZ"),
+            device_label(dev));
+    runtime_lifecycle_schedule(dev->owner);
+}
+
+static void runtime_lifecycle_queue_health(ConfigDeviceRuntime *dev,
+                                           const char *reason) {
+    if (!dev || !dev->owner || !dev->owner->lifecycle_queue)
+        return;
+
+    if (dev->lifecycle_health_queued || dev->lifecycle_connect_queued)
+        return;
+
+    LifecycleCommand *cmd = g_new0(LifecycleCommand, 1);
+    cmd->type = LIFECYCLE_CMD_HEALTH;
+    cmd->dev = dev;
+    cmd->reason = g_strdup(reason);
+
+    dev->lifecycle_health_queued = true;
+    g_queue_push_tail(dev->owner->lifecycle_queue, cmd);
+
+    runtime_lifecycle_schedule(dev->owner);
+}
+
+static void device_check_health_once(ConfigDeviceRuntime *dev) {
+    if (!dev || !device_has_bluez_device_path(dev) || !device_can_mark_disconnected(dev))
+        return;
+
+    char *device_path = device_dup_device_path(dev);
+    bool connected = false;
+
+    bool ok = mb_bluez_get_device_bool_property(dev->owner->bus,
+                                                device_path,
+                                                "Connected",
+                                                &connected);
+
+    if (!ok || !connected)
+        device_mark_disconnected(dev, "health check");
+
+    g_free(device_path);
+}
+
+static gboolean lifecycle_process_next_cb(gpointer user_data) {
+    ConfigDirRuntime *rt = user_data;
+    if (!rt)
+        return G_SOURCE_REMOVE;
+
+    rt->lifecycle_source_id = 0;
+
+    if (rt->lifecycle_busy)
+        return G_SOURCE_REMOVE;
+
+    LifecycleCommand *cmd = rt->lifecycle_queue ? g_queue_pop_head(rt->lifecycle_queue) : NULL;
+    if (!cmd)
+        return G_SOURCE_REMOVE;
+
+    rt->lifecycle_busy = true;
+
+    if (cmd->dev) {
+        switch (cmd->type) {
+            case LIFECYCLE_CMD_CONNECT:
+                cmd->dev->lifecycle_connect_queued = false;
+                g_print("Lifecycle processing CONNECT for %s%s%s.\n",
+                        device_label(cmd->dev),
+                        cmd->reason && *cmd->reason ? ": " : "",
+                        cmd->reason && *cmd->reason ? cmd->reason : "");
+                if (!device_try_start_streaming(cmd->dev))
+                    g_print("Device %s did not reach STREAMING during lifecycle transaction.\n",
+                            device_label(cmd->dev));
+                break;
+
+            case LIFECYCLE_CMD_HEALTH:
+                cmd->dev->lifecycle_health_queued = false;
+                device_check_health_once(cmd->dev);
+                break;
+        }
+    }
+
+    lifecycle_command_free(cmd);
+    rt->lifecycle_busy = false;
+
+    if (rt->lifecycle_queue && !g_queue_is_empty(rt->lifecycle_queue))
+        runtime_lifecycle_schedule(rt);
+
+    return G_SOURCE_REMOVE;
+}
 
